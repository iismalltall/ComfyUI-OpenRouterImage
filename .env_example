OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=<openrouter api key>

WANGSU_BASE_URL=<wangsu base url>
WANGSU_API_KEY=<wangsu api key>

# Wangsu OpenAI-compatible image endpoints (one pair per endpoint)
# Used by WangsuImageNode in wangsu_image_generate_node.py

# POST /v1/images/generations  -> client.images.generate()
WANGSU_IMAGE_GENERATE_URL=<url>
WANGSU_IMAGE_GENERATE_API_KEY=<key>

# POST /v1/images/edits  -> client.images.edit()
WANGSU_IMAGE_EDIT_URL=<url>
WANGSU_IMAGE_EDIT_API_KEY=<key>

# POST /v1/images/variations  -> client.images.create_variation()
WANGSU_IMAGE_VARIATION_URL=<url>
WANGSU_IMAGE_VARIATION_API_KEY=<key>
